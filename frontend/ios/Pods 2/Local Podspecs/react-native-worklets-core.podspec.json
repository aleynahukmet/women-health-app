{
  "name": "react-native-worklets-core",
  "version": "1.3.3",
  "summary": "A Worklet runner for React Native",
  "homepage": "https://github.com/margelo/react-native-worklets-core#readme",
  "license": "MIT",
  "authors": "Christian Falch <christian.falch@gmail.com> (https://github.com/chrfalch)",
  "platforms": {
    "ios": "11.0"
  },
  "source": {
    "git": "https://github.com/margelo/react-native-worklets-core.git",
    "tag": "1.3.3"
  },
  "source_files": [
    "ios/**/*.{h,m,mm}",
    "cpp/**/*.{h,cpp}"
  ],
  "dependencies": {
    "React-Core": [],
    "React-Codegen": [],
    "RCT-Folly": [],
    "RCTRequired": [],
    "RCTTypeSafety": [],
    "ReactCommon/turbomodule/core": []
  },
  "compiler_flags": "-DFOLLY_NO_CONFIG -DFOLLY_MOBILE=1 -DFOLLY_USE_LIBCPP=1 -Wno-comma -Wno-shorten-64-to-32 -DRCT_NEW_ARCH_ENABLED=1",
  "pod_target_xcconfig": {
    "HEADER_SEARCH_PATHS": "\"$(PODS_ROOT)/boost\"",
    "OTHER_CPLUSPLUSFLAGS": "-DFOLLY_NO_CONFIG -DFOLLY_MOBILE=1 -DFOLLY_USE_LIBCPP=1",
    "CLANG_CXX_LANGUAGE_STANDARD": "c++17"
  }
}
