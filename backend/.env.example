# Project Settings
PROJECT_NAME="Women's Health App"
API_V1_STR="/api/v1"

# SECURITY: Change this to a long random string in production
# Example: openssl rand -hex 32
SECRET_KEY=your_actual_secret_key_here

# Database Settings
# Production requires PostgreSQL (e.g., postgresql://user:password@localhost:5432/db_name)
SQLALCHEMY_DATABASE_URI=postgresql://postgres:postgres@localhost:5432/app

# JWT Settings
ACCESS_TOKEN_EXPIRE_MINUTES=11520 # 8 days
